{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>TimSchoenle/actions//configs/renovate/default"],
  "github-actions": {
    "managerFilePatterns": [
      "/(^|/)(workflow-templates|\\.(?:github|gitea|forgejo)/(?:workflows|actions))/.+\\.ya?ml$/",
      "/(^|/)action\\.ya?ml$/",
      "/(^|/)workflow\\.ya?ml$/",
      "/(^|/)workflows/(.*/)?workflow\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Auto-merge safe dev updates",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["major", "minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Auto-merge @types/* (non-major)",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "matchPackageNames": ["/^@types//"]
    },
    {
      "description": "Review majors for TypeScript",
      "groupName": "typescript major",
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Bundle graphql and the graphql codegen toolchain into a single PR. These must upgrade together (a graphql major such as v17 breaks codegen unless the generators move with it), and every bump requires re-running codegen to regenerate src/generated/graphql.ts, so they are never auto-merged.",
      "groupName": "graphql codegen",
      "matchPackageNames": [
        "graphql",
        "@graphql-typed-document-node/core",
        "@octokit/graphql-schema",
        "/^@graphql-codegen//"
      ],
      "separateMajorMinor": false,
      "separateMinorPatch": false,
      "automerge": false
    }
  ]
}
