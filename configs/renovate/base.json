{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Base configuration to handle custom versioning for all resources in this repository.",
  "extends": [
    "github>TimSchoenle/actions//configs/renovate/actions",
    "github>TimSchoenle/actions//configs/renovate/workflows"
  ],
  "customManagers": [
    {
      "description": "Handle internal pinned actions/workflows with or without tag= comments across formatting styles",
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)(workflow-templates|\\.(?:github|gitea|forgejo)/(?:workflows|actions))/.+\\.ya?ml$/",
        "/(^|/)action\\.ya?ml$/",
        "/(^|/)workflow\\.ya?ml$/",
        "/(^|/)workflows/(.*/)?workflow\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?<indent>\\s*)uses\\s*:\\s*(?<quote>['\"]?)(?<depPath>TimSchoenle\\/actions(?:\\/[^@'\"\\s#]+)?)@(?<currentDigest>[a-fA-F0-9]{40})(?<quoteEnd>['\"]?)\\s*#\\s*(?<hasTagPrefix>(?:renovate:\\s*)?tag\\s*=\\s*)?(?<currentValue>(?:actions|workflows)-[^\\s#'\"`]+)"
      ],
      "depNameTemplate": "TimSchoenle/actions",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "regex:^(?<compatibility>(?:actions|workflows)-.*)[-/]v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)?$",
      "autoReplaceStringTemplate": "{{{indent}}}uses: {{{quote}}}{{{depPath}}}@{{#if newDigest}}{{{newDigest}}}{{/if}}{{#unless newDigest}}{{{newValue}}}{{/unless}}{{{quoteEnd}}} # {{#if hasTagPrefix}}tag={{{newValue}}}{{/if}}{{#unless hasTagPrefix}}{{{newValue}}}{{/unless}}"
    }
  ]
}
