{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Default configuration for Renovate",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigests",
    "workarounds:all",
    "github>TimSchoenle/actions//configs/renovate/base",
    "github>TimSchoenle/actions//configs/renovate/ci-automerge"
  ],
  "dependencyDashboardApproval": false,
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "prCreation": "immediate",
  "timezone": "Europe/Berlin",
  "minimumReleaseAge": "3 days",
  "ignoreUnstable": true,
  "respectLatest": true,
  "separateMajorMinor": true,
  "separateMinorPatch": true,
  "rollbackPrs": true,
  "platformAutomerge": true,
  "automergeType": "pr",
  "assigneesFromCodeOwners": true,
  "reviewersFromCodeOwners": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["dependencies", "security", "vulnerability"],
    "automerge": true,
    "dependencyDashboardApproval": false,
    "prCreation": "immediate"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 4am on monday"],
    "automerge": true
  },
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "commitHourlyLimit": 0,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 8,
  "branchConcurrentLimit": 8,
  "gitIgnoredAuthors": ["actions-maintenance-bot", "actions-maintenance-bot[bot]@users.noreply.github.com"],
  "packageRules": [
    {
      "description": "Auto-merge all non-major updates",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "lockFileMaintenance"],
      "automerge": true
    },
    {
      "description": "Disable dependency dashboard approval for all packages",
      "matchPackageNames": ["*"],
      "dependencyDashboardApproval": false
    },
    {
      "description": "Group all minor and patch updates for GitHub Actions",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major action updates"
    }
  ]
}
