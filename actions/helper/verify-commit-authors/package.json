{
  "name": "actions-helper-verify-commit-authors",
  "version": "1.0.0",
  "description": "Verifies that all commits in a PR are authored by a specific set of users and are signed.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run codegen && bun build ./src/generated/index.ts --outfile ./dist/index.js --target node --minify --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "codegen": "graphql-codegen"
  },
  "dependencies": {
    "actions-util": "workspace:*",
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@fast-check/vitest": "0.4.1",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/typed-document-node": "6.1.8",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@octokit/graphql-schema": "15.26.1",
    "@types/node": "26.1.1",
    "fast-check": "4.9.0",
    "graphql": "16.14.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
