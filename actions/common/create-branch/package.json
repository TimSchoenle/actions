{
  "name": "actions-common-create-branch",
  "version": "1.0.0",
  "description": "Create a branch from a base branch, or reset it to that base branch when it already exists",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build ./src/generated/index.ts --outfile ./dist/index.js --target node --minify --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@fast-check/vitest": "0.4.1",
    "@types/node": "26.1.1",
    "fast-check": "4.9.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
