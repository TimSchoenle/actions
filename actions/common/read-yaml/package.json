{
  "name": "actions-common-read-yaml",
  "version": "1.0.0",
  "description": "Read values from YAML files using dot notation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build ./src/generated/index.ts --outfile ./dist/index.js --target node --minify --production",
