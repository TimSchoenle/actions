{
  "name": "actions",
  "version": "1.0.0",
  "scripts": {
    "build:workspaces": "bun run generate-action-sources && bun run --workspaces build",
    "create-action": "bun scripts/create-action.ts",
    "remove-action": "bun scripts/remove-action.ts",
    "create-workflow": "bun scripts/create-workflow.ts",
    "generate-maven-central-signing-key": "bun scripts/generate-maven-central-signing-key.ts",
    "remove-workflow": "bun scripts/remove-workflow.ts",
    "generate-docs": "bun scripts/generate-docs.ts",
    "generate-ci-required": "bun scripts/generate-ci-required.ts",
    "generate-action-sources": "bun scripts/generate-action-sources.ts",
    "check-action-sources": "bun scripts/generate-action-sources.ts --check",
    "check-action-dist": "bun scripts/check-action-dist.ts",
    "lint": "eslint \"scripts/**/*.ts\" \"actions/**/src/**/*.ts\" \"packages/**/src/**/*.ts\"",
    "typecheck": "bun run generate-action-sources && bun run --workspaces typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "prepare": "husky"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@fast-check/vitest": "0.4.1",
    "@inquirer/prompts": "8.5.2",
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "@vitest/coverage-v8": "4.1.10",
    "ansi-escapes": "7.3.0",
    "chardet": "2.2.0",
    "cli-width": "4.1.0",
    "eslint": "10.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-no-secrets": "2.3.3",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-sonarjs": "4.2.0",
    "eslint-plugin-unicorn": "72.0.0",
    "husky": "9.1.7",
    "iconv-lite": "0.7.3",
    "lint-staged": "17.1.0",
    "mute-stream": "4.0.0",
    "prettier": "3.9.5",
    "run-async": "4.0.6",
    "rxjs": "7.8.2",
    "signal-exit": "4.1.0",
    "typescript": "7.0.2",
    "typescript-eslint": "8.65.0",
    "vitest": "4.1.10",
    "wrap-ansi": "10.0.0",
    "yaml": "2.9.0"
  },
  "dependencies": {
    "actions-util": "workspace:*",
    "chalk": "5",
    "inquirer": "14.0.2",
    "openpgp": "6.3.1"
  },
  "workspaces": [
    "actions/**/*",
    "workflows/**/*",
    "packages/*"
  ]
}
